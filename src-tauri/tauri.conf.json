{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tradu-bee",
  "version": "0.1.0",
  "identifier": "com.tdclub.tradu-bee",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tradu-bee",
        "width": 1280,
        "height": 720,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
      "active": true,
      "category": "Games",
      "copyright": "Traduction Club!",
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "longDescription": "Mod Launcher for DDLC developed by Traduction Club!",
      "macOS": {},
      "publisher": "Traduction Club!",
      "shortDescription": "Tradu-Bee Launcher",
      "targets": ["nsis", "msi"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": {
          "language": "es-ES"
        },
        "nsis": {
          "installMode": "currentUser",
          "displayLanguageSelector": true
        }
      }
    }
}
